# Test-only environment overrides. Copy to `.env.test.local` and fill in.
# Loaded by playwright.config.ts BEFORE .env.local, so values here override
# the regular dev env for the test run only.
#
# Goal: E2E tests must NEVER write to the production database.
# Use a Neon branch (recommended: branch name `e2e`) so the schema matches
# prod but the data is throwaway.
#
# Create the branch in Neon UI or with `neonctl branches create --name e2e`,
# then copy its connection string here.

# Connection string for the isolated test branch
DATABASE_URL=postgresql://user:pwd@ep-e2e-host-XXXX.neon.tech/db?sslmode=require

# Safety net (defence in depth). Both are optional but strongly recommended.
#
# 1) Hard block: if DATABASE_URL contains PROD_DB_HOST_MARKER, every /api/test/*
#    endpoint returns 403. Set it to a fragment of the *production* Neon
#    hostname so a misconfigured DATABASE_URL cannot be mutated by tests.
PROD_DB_HOST_MARKER=ep-prod-host-fragment

# 2) Hard require: if E2E_REQUIRE_DB_MARKER is set, DATABASE_URL MUST contain
#    it for /api/test/* to work. Set it to a fragment of the e2e Neon
#    hostname — guarantees tests can only run against that branch.
E2E_REQUIRE_DB_MARKER=ep-e2e-host-fragment

# Production-runtime opt-in (CI only — you normally DON'T set this locally).
#
# On CI the E2E job runs a real production server (`next start`,
# NODE_ENV=production) for speed/stability. Under production runtime the
# /api/test/* guard (lib/test-mode.ts) is OFF by default and additionally
# requires this explicit opt-in PLUS both markers above to be set. CI injects
# E2E_ALLOW_PRODUCTION_SERVER=true automatically via playwright.config.ts
# (webServer.env), so you don't put it here. Locally tests run `next dev`
# (NODE_ENV=development) where this flag is ignored — leave it unset.
#
# E2E_ALLOW_PRODUCTION_SERVER=true

# These typically stay the same as in .env.local
NEXTAUTH_SECRET=copy_from_env_local
NEXTAUTH_URL=http://localhost:3000
